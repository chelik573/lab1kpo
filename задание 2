#include <iostream>
#include <cstring>
using namespace std;
int main() {
	setlocale(LC_ALL, "RU");
	string s;
	cin >> s;
	string target = "hello";
	int j = 0;
	for (int i = 0; i < s.length(); i++) {
		if (j < target.length() && s[i] == target[j]) {
			j++;
		}
	}
	if (j == target.length()) {
		cout << "YES";
	}
	else { cout << "NO"; }
	return 0;
}
